# Vapi credentials (dashboard.vapi.ai) — only needed by the configure scripts,
# which create/update the assistants. The runtime server doesn't use them.
VAPI_API_KEY=your_vapi_private_key_here
# Leave blank on first run — each configure script creates a new assistant and prints its ID.
# PolicyVoice assistant (configure-complete-system.js):
VAPI_ASSISTANT_ID=
# Operations Co-Pilot assistant (configure-invan-system.js):
INVAN_ASSISTANT_ID=

# Server port
PORT=3001
